{
  "name": "skatespot-monorepo",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "build:web": "npm run build --workspace=apps/web",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "db:push": "npm run db:push --workspace=apps/web",
    "db:seed": "npm run db:seed --workspace=apps/web",
    "db:reset": "npm run db:reset --workspace=apps/web"
  }
}
